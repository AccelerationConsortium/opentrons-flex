{
  "sila_server": {
    "hostname": "127.0.0.1",
    "port": 50051,
    "tls": false,
    "require_client_auth": false,
    "root_certificates": null,
    "certificate_chain": null,
    "private_key": null,
    "options": {},
    "uuid": "9f1d2b5a-7c3e-4a18-9b2c-1e7f5a3d8c41",
    "name": "Opentrons Flex Smoketest",
    "type": "LiquidHandler",
    "description": "Local smoketest config for the Opentrons Flex connector simulator",
    "version": "0.9.0",
    "vendor_url": "https://opentrons.com/",
    "default_lifetime": 3600.0
  },
  "cloud_server_endpoint": null,
  "discovery": null,
  "logging": {
    "version": 1,
    "disable_existing_loggers": false,
    "formatters": {
      "simple": {
        "format": "%(asctime)s %(levelname)s %(name)s: %(message)s"
      }
    },
    "handlers": {
      "stderr": {
        "class": "logging.StreamHandler",
        "stream": "ext://sys.stderr",
        "formatter": "simple"
      }
    },
    "root": {
      "level": "INFO",
      "handlers": ["stderr"]
    }
  },
  "use_simulator": true,
  "simulated_heater_shaker": true,
  "simulated_flex_stacker": true,
  "simulated_absorbance_reader": true,
  "simulated_temperature_module": true,
  "simulated_thermocycler": true,
  "simulated_gripper": true,
  "with_robot_server": true,
  "robot_server_tcp_port": 31950,
  "lock_timeout_s": 10,
  "labware_movement_config": null,
  "run_mutation_ledger_path": "/private/tmp/unitelabs-opentrons-flex-smoketest/run-mutations.jsonl",
  "run_mutation_token_env": "UNITELABS_RUN_MUTATION_TOKEN",
  "run_mutation_actor_env": "UNITELABS_RUN_MUTATION_ACTOR"
}
